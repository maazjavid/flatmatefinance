generator client {
  // Prisma v7 generator. The connection adapter is passed at runtime in
  // `src/lib/prisma.ts` (better-sqlite3 for local dev).
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  // SQLite for local dev (`file:./dev.db`). Docker/AWS use
  // `docker/prisma/schema.postgresql.prisma` copied over at build time.
  provider = "sqlite"
}

// SQLite doesn't have native enums. Role is a plain string column, validated
// at the application layer. Allowed values: "ADMIN" | "MEMBER".
// (Kept as a string instead of a Prisma enum so the schema works on both
// SQLite and Postgres without changes.)

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  name         String
  // Optional so Google-authenticated users can exist without a local password.
  passwordHash String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  memberships  FlatMember[]
  expensesPaid Expense[]    @relation("ExpensePaidBy")
  paymentsFrom Payment[]    @relation("PaymentFrom")
  paymentsTo   Payment[]    @relation("PaymentTo")
  rentChargesCreated RentCharge[] @relation("RentChargeCreatedBy")
  rentSplits         RentSplit[]
}

model Flat {
  id         String       @id @default(cuid())
  name       String
  inviteCode String       @unique
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  members    FlatMember[]
  expenses   Expense[]
  payments   Payment[]
  rentCharges RentCharge[]
}

model FlatMember {
  id        String    @id @default(cuid())
  flatId    String
  userId    String
  role      String    @default("MEMBER")
  // ACTIVE | REMOVED — soft removal keeps history without hard deletes.
  status    String    @default("ACTIVE")
  joinedAt  DateTime  @default(now())
  removedAt DateTime?
  flat      Flat      @relation(fields: [flatId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([flatId, userId])
  @@index([userId])
  @@index([flatId, status])
}

model Expense {
  id          String   @id @default(cuid())
  flatId      String
  paidById    String
  amountCents Int
  description String
  expenseDate DateTime @default(now())
  createdAt   DateTime @default(now())
  flat        Flat     @relation(fields: [flatId], references: [id], onDelete: Cascade)
  paidBy      User     @relation("ExpensePaidBy", fields: [paidById], references: [id])

  @@index([flatId, expenseDate])
}

model Payment {
  id           String   @id @default(cuid())
  flatId       String
  fromUserId   String
  toUserId     String
  amountCents  Int
  paymentDate  DateTime @default(now())
  createdAt    DateTime @default(now())
  flat         Flat     @relation(fields: [flatId], references: [id], onDelete: Cascade)
  fromUser     User     @relation("PaymentFrom", fields: [fromUserId], references: [id])
  toUser       User     @relation("PaymentTo", fields: [toUserId], references: [id])

  @@index([flatId, paymentDate])
}

// One flat-level rent charge, split equally across active members at creation time.
model RentCharge {
  id          String      @id @default(cuid())
  flatId      String
  amountCents Int
  dueDate     DateTime?
  label       String?
  createdAt   DateTime    @default(now())
  createdById String
  flat        Flat        @relation(fields: [flatId], references: [id], onDelete: Cascade)
  createdBy   User        @relation("RentChargeCreatedBy", fields: [createdById], references: [id])
  splits      RentSplit[]

  @@index([flatId, createdAt])
}

// Per-member share of a rent charge — tracks payment, reminders, and proof metadata.
model RentSplit {
  id                String     @id @default(cuid())
  rentChargeId      String
  userId            String
  amountCents       Int
  // OWING | PAID
  status            String     @default("OWING")
  notificationCount Int        @default(0)
  lastNotifiedAt    DateTime?
  paidAt            DateTime?
  proofFileName     String?
  proofStorageKey   String?
  proofUploadedAt   DateTime?
  rentCharge        RentCharge @relation(fields: [rentChargeId], references: [id], onDelete: Cascade)
  user              User       @relation(fields: [userId], references: [id])

  @@unique([rentChargeId, userId])
  @@index([rentChargeId])
  @@index([userId, status])
}
