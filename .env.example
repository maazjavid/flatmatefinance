# --- Database ---
# Local dev uses SQLite (no server required). For production swap to a
# Postgres connection string AND change `provider = "sqlite"` to `"postgresql"`
# in prisma/schema.prisma.
DATABASE_URL="file:./dev.db"

# --- NextAuth ---
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-random-secret"
AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Google OAuth (optional but recommended for "Continue with Google") ---
# Redirect URI configured in Google Cloud: {AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Resend (required for forgot-password emails) ---
# Sign up at https://resend.com — free tier covers 3,000 emails/month and
# 100/day. Set RESEND_FROM_EMAIL to an address on a verified domain (or
# `onboarding@resend.dev` for quick local testing).
RESEND_API_KEY=
RESEND_FROM_EMAIL="onboarding@resend.dev"
