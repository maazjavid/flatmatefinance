# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/flatmate_finance?schema=public"

# NextAuth (generate with: openssl rand -base64 32)
AUTH_SECRET="replace-with-a-random-secret"

# Optional: email (Resend)
# RESEND_API_KEY=

# Optional: S3 receipts
# AWS_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET_NAME=
